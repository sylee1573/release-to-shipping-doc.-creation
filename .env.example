# ─────────────────────────────────────────────
# AI 프로바이더 설정 (이 1줄만 바꾸면 전체 전환)
# ─────────────────────────────────────────────
AI_PROVIDER=anthropic        # anthropic | openai | gemini | ollama

# Anthropic (기본값)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL_HEAVY=claude-sonnet-4-5
ANTHROPIC_MODEL_LIGHT=claude-haiku-4-5-20251001

# OpenAI (전환 시 주석 해제)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL_HEAVY=gpt-4o
# OPENAI_MODEL_LIGHT=gpt-4o-mini

# Google Gemini (전환 시 주석 해제)
# GEMINI_API_KEY=...
# GEMINI_MODEL_HEAVY=gemini-1.5-pro
# GEMINI_MODEL_LIGHT=gemini-1.5-flash

# Ollama 로컬 (설치형 고객사 — 인터넷 차단 환경)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL_HEAVY=llama3.1:70b
# OLLAMA_MODEL_LIGHT=llama3.1:8b

# ─────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/order_automation

# ─────────────────────────────────────────────
# JWT
# ─────────────────────────────────────────────
JWT_SECRET_KEY=change-me-to-a-random-256bit-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ─────────────────────────────────────────────
# Solapi (카카오 알림톡 + SMS)
# ─────────────────────────────────────────────
SOLAPI_API_KEY=
SOLAPI_API_SECRET=
SOLAPI_SENDER_PHONE=
SOLAPI_KAKAO_PFID=

# ─────────────────────────────────────────────
# 파일 저장
# ─────────────────────────────────────────────
UPLOAD_DIR=/data/uploads
EXCEL_OUTPUT_DIR=/data/outputs

# ─────────────────────────────────────────────
# 앱 설정
# ─────────────────────────────────────────────
ENVIRONMENT=development          # development | production
SENTRY_DSN=
FRONTEND_URL=http://localhost:5173
